{
  "name": "astro-svelta-base-template",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "astro": "astro",
    "lint": "eslint . --ext .js,.ts,.astro,.svelte",
    "format": "prettier --write .",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "@fontsource-variable/orbitron": "^5.2.8",
    "@fontsource/cutive-mono": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "astro": "^7.0.2",
    "astro-compressor": "^1.3.0",
    "astro-min": "^1.3.1",
    "astro-seo": "^1.1.0",
    "nanostores": "^1.3.0",
    "svelte": "^5.56.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-js": "github:eslint/js",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.19.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-eslint": "^16.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{js,ts,astro,svelte}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,html}": [
      "prettier --write"
    ]
  }
}
