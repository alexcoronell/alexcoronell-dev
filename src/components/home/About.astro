---
/* Components */
import Section from "../shared/Section.astro";
import ProfilePicture from "../shared/ProfilePicture.astro";

/* Utils */
import { getLangFromUrl, useTranslations } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Section title={t("about.title") as string} index={1}>
  <article class="About">
    <ProfilePicture />
    <div class="About__content">
      {
        Object.entries(t("about.content")).map(([_, value]) => {
          return <p>{value}</p>;
        })
      }
    </div>
  </article>
</Section>

<style>
  @reference "tailwindcss";
  .About {
    @apply lg:grid lg:grid-cols-2;
  }
</style>
