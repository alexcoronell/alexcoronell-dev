---
/* Components */
import CloseIcon from "@components/ui/icons/CloseIcon.astro";
import MenuIcon from "@components/ui/icons/MenuIcon.astro";
import SpainFlagIcon from "@components/ui/icons/SpainFlagIcon.astro";
import UsaFlagIcon from "@components/ui/icons/UsaFlagIcon.astro";

/* Utils */
import { getLangFromUrl, useTranslations } from "@/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="Menu">
  <label for="menu-toggle">
    <MenuIcon class="MenuIcon" aria-hidden="true" />
    <span class="sr-only">
      {lang === "es" ? "Abrir menú de navegación" : "Open navigation menu"}
    </span>
  </label>
  <input type="checkbox" id="menu-toggle" class="hidden" />
  <div class="Menu__overlay"></div>
  <nav class="Menu__nav" id="menu-nav">
    <div class="flex justify-end">
      <label for="menu-toggle">
        <CloseIcon class="CloseIcon" aria-hidden="true" />
        <span class="sr-only">
          {
            lang === "es"
              ? "Cerrar menú de navegación"
              : "Close navigation menu"
          }
        </span>
      </label>
    </div>
    <ul>
      {
        Object.entries(t("nav")).map(([key, value], index) => {
          const sectionId = value;
          return (
            <li>
              <button
                class="Menu__item"
                onclick={`scrollToSection('${sectionId}')`}
                aria-label={`Go to ${(value as string).charAt(0).toUpperCase() + (value as string).slice(1)} section`}
              >
                <span class="Menu__itemIndex">0{index + 1}.</span>
                <span class="Menu__itemName">
                  {(value as string).charAt(0).toUpperCase() +
                    (value as string).slice(1)}
                </span>
                <span class="sr-only">
                  Go to{" "}
                  {(value as string).charAt(0).toUpperCase() +
                    (value as string).slice(1)}{" "}
                  section
                </span>
              </button>
            </li>
          );
        })
      }
    </ul>
    <div class="Nav__resume">
      <a
        href={`/assets/resume/${t("resumeName")}`}
        class="btn btn-primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t("resumeShortName")}
      </a>
    </div>
    <div class="Nav__flags">
      {
        lang === "es" ? (
          <a href="/en" aria-label="Cambiar a inglés">
            <UsaFlagIcon class="FlagIcon" aria-hidden="true" />
          </a>
        ) : (
          <a href="/" aria-label="Switch to Spanish">
            <SpainFlagIcon class="FlagIcon" aria-hidden="true" />
          </a>
        )
      }
    </div>
  </nav>
</div>

<style>
  @reference "tailwindcss";

  .Menu {
    @apply z-9999999999 relative w-full p-4 flex items-center justify-end xl:absolute xl:px-12;
  }

  .Menu__overlay {
    @apply fixed inset-0 h-screen opacity-0 translate-x-full bg-(--primary)/20 xl:hidden;
    backdrop-filter: blur(4px);
  }

  .MenuIcon,
  .CloseIcon {
    @apply w-12 h-12 text-(--primary);
  }

  #menu-nav {
    @apply fixed p-4 w-4/5 right-0 top-0 bottom-0 left-auto max-xl:min-h-screen max-xl:max-h-screen bg-(--dark-surface)/80 border-l border-(--primary) max-xl:translate-x-full flex flex-col gap-y-4
    xl:static xl:border-0 xl:w-auto xl:flex-row xl:items-center xl:justify-end xl:gap-9 xl:h-auto xl:py-0 xl:px-0 xl:bg-transparent 2xl:px-16;
  }

  #menu-nav ul {
    @apply flex flex-col items-center gap-4 py-12 xl:flex-row xl:gap-8 xl:py-0;
  }

  .Menu__item {
    font-family: "Orbitron Variable", sans-serif;
    @apply flex flex-col items-center gap-0 xl:flex-row xl:gap-1;
  }

  .Menu__itemIndex {
    @apply text-(--primary) text-sm mb-0 2xl:text-lg;
  }
  .Menu__itemName {
    @apply text-lg xl:text-base 2xl:text-xl;
  }

  .Nav__resume {
    @apply pb-4 flex items-center justify-center xl:pb-0 text-nowrap;
  }

  .Nav__flags {
    @apply flex justify-center;
  }

  .FlagIcon {
    @apply w-8 h-8;
  }

  #menu-toggle:checked ~ #menu-nav {
    @apply translate-x-0;
  }

  #menu-toggle:checked ~ .Menu__overlay {
    @apply opacity-100 translate-x-0;
  }

  .Menu label {
    @apply xl:hidden;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  declare global {
    interface Window {
      scrollToSection: (sectionId: string) => void;
    }
  }

  function scrollToSection(sectionId: string) {
    const element = document.getElementById(sectionId);
    if (element) {
      element.scrollIntoView({ behavior: "smooth" });
      const menuToggle = document.getElementById(
        "menu-toggle",
      ) as HTMLInputElement;
      if (menuToggle) {
        menuToggle.checked = false;
      }
    }
  }

  // Make function globally available
  window.scrollToSection = scrollToSection;
</script>
